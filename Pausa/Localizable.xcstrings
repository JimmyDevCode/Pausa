    "exercise.grounding.closing" : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "¿Te sentiste más presente después de hacerlo?"
          }
        }
      }
    },
    "exercise.grounding.detail" : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nombra tres cosas que ves, dos que sientes y una que escuchas. La idea es aterrizar, no resolver todo."
          }
        }
      }
    },
    "exercise.grounding.evidence" : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Las técnicas de grounding se usan mucho en regulación emocional y trabajo con atención. Tienen apoyo práctico amplio, aunque el respaldo experimental es menos sólido que en respiración lenta o relajación muscular."
          }
        }
      }
    },
    "exercise.grounding.origin" : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Este tipo de ejercicio viene de enfoques contemporáneos de regulación emocional y atención plena, centrados en volver al presente a través de los sentidos."
          }
        }
      }
    },
    "exercise.grounding.summary" : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vuelve a lo que puedes ver, sentir y escuchar."
          }
        }
      }
    },
    "exercise.grounding.title" : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Atención al presente"
          }
        }
      }
    },
    "exercise.inhale_exhale.care" : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si marearte o hiperventilar te resulta fácil, baja el ritmo y vuelve a una respiración natural."
          }
        }
      }
    },
    "exercise.inhale_exhale.closing" : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "¿Tu respiración quedó un poco más estable?"
          }
        }
      }
    },
    "exercise.inhale_exhale.detail" : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sigue la cuenta visual y deja que el aire marque el ritmo. Si te distraes, vuelve sin exigirte."
          }
        }
      }
    },
    "exercise.inhale_exhale.evidence" : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La respiración diafragmática y acompasada se estudia como herramienta simple de regulación fisiológica y emocional. Suele ayudar a bajar activación cuando se hace de forma cómoda, aunque no todas las personas responden igual."
          }
        }
      }
    },
    "exercise.inhale_exhale.origin" : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Las prácticas de respiración consciente existen en múltiples culturas. En tradiciones de yoga, taoísmo y meditación se usaron para entrenar atención, energía y calma."
          }
        }
      }
    },
    "exercise.inhale_exhale.summary" : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Temporizador suave para seguir tu respiración."
          }
        }
      }
    },
    "exercise.inhale_exhale.title" : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Inhalar y exhalar"
          }
        }
      }
    },
    "exercise.navigation.title" : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ejercicios"
          }
        }
      }
    },
    "exercise.relax.care" : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si una zona duele o está lesionada, no la contraigas ni la fuerces."
          }
        }
      }
    },
    "exercise.relax.closing" : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "¿Notas algo menos de tensión física?"
          }
        }
      }
    },
    "exercise.relax.detail" : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Suelta la frente, baja los hombros y deja la lengua descansar. A veces el cuerpo necesita permiso para soltar."
          }
        }
      }
    },
    "exercise.relax.evidence" : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La relajación muscular progresiva y ejercicios corporales breves tienen respaldo en investigación para reducir tensión física y ansiedad en muchas personas, sobre todo cuando se repiten con práctica. Aun así, no reemplaza atención clínica cuando hace falta."
          }
        }
      }
    },
    "exercise.relax.origin" : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Las versiones modernas de relajación muscular se popularizaron en el siglo XX con Edmund Jacobson, quien estudió cómo liberar tensión corporal de forma deliberada."
          }
        }
      }
    },
    "exercise.relax.summary" : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Afloja mandíbula, hombros y respiración en un minuto."
          }
        }
      }
    },
    "exercise.relax.title" : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Relajación breve"
          }
        }
      }
