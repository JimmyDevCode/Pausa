        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Enviar"
          }
        }
      }
    },
    "chat.disclaimer" : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Este chat acompaña con calma y herramientas cortas. No reemplaza ayuda profesional."
          }
        }
      }
    },
    "chat.navigation.title" : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Chat de apoyo"
          }
        }
      }
    },
    "chat.placeholder" : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Escribe cómo te sientes"
          }
        }
      }
    },
    "chat.reply.abrumado" : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cuando todo cae junto, suele ayudar una pausa corta para volver al presente y soltar una capa de ruido."
          }
        }
      }
    },
    "chat.reply.ansiedad" : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vamos de a poco. Si te sirve, te acompaño a una respiración guiada de 1 minuto para bajar un poco la activación."
          }
        }
      }
    },
    "chat.reply.default" : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Te leo. Si quieres, podemos hacer esto simple: dime qué pesa más ahora mismo o te sugiero una herramienta corta dentro de la app."
          }
        }
      }
    },
    "chat.reply.intenso" : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gracias por decirlo. No hace falta que ordenes todo ahora. Podemos hacer un check-in simple o una pausa guiada para bajar un poco la intensidad."
          }
        }
      }
    },
    "chat.reply.sueno" : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si tu cabeza sigue acelerada, prueba una relajación breve. La idea no es obligarte a dormir, sino soltar un poco el cuerpo."
          }
        }
      }
    },
    "chat.reply.urgent" : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Siento que esto se siente muy pesado. Esta app no reemplaza ayuda profesional. Si hay riesgo inmediato, busca ayuda de emergencia o contacta ahora mismo a alguien de confianza que pueda estar contigo."
          }
        }
      }
    },
    "checkin.button.save" : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
