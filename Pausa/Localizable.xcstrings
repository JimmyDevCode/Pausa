    "exercise.anti_stress_pause.closing" : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "¿Esto se siente un poco más manejable ahora?"
          }
        }
      }
    },
    "exercise.anti_stress_pause.detail" : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Respira, identifica qué te pesa más y elige una sola acción pequeña para después. El objetivo es simplificar."
          }
        }
      }
    },
    "exercise.anti_stress_pause.evidence" : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esta práctica junta dos ayudas simples: una pausa para respirar y una forma de calmar un poco la mente."
          }
        }
      }
    },
    "exercise.anti_stress_pause.origin" : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Este formato no viene de una tradición única. Reúne ideas de regulación breve, mindfulness aplicado y estrategias modernas para reducir carga mental."
          }
        }
      }
    },
    "exercise.anti_stress_pause.summary" : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dos minutos para bajar intensidad y ordenar una sola prioridad."
          }
        }
      }
    },
    "exercise.anti_stress_pause.title" : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pausa anti-estrés"
          }
        }
      }
    },
    "exercise.badge.context" : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Origen"
          }
        }
      }
    },
    "exercise.breathing_444.care" : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si sostener el aire te incomoda, reduce la cuenta o elimina la pausa. La idea es regularte, no forzar el cuerpo."
          }
        }
      }
    },
    "exercise.breathing_444.closing" : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "¿Te ayudó a sentir un poco más de aire?"
          }
        }
      }
    },
    "exercise.breathing_444.detail" : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Inhala 4 segundos, sostén 4 y exhala 4. Está inspirada en respiraciones lentas y reguladas: acompasa el cuerpo sin exigirte hacerlo perfecto."
          }
        }
      }
    },
    "exercise.breathing_444.evidence" : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La evidencia sobre respiración lenta y guiada muestra mejoras frecuentes en estrés y ansiedad percibidos cuando se practica con suavidad y de forma repetida. El beneficio suele venir del ritmo lento, no de aguantar más, y puede variar según la persona."
          }
        }
      }
    },
    "exercise.breathing_444.origin" : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El trabajo consciente con la respiración aparece desde hace siglos en tradiciones contemplativas. En el yoga se conoce como pranayama, una práctica dedicada a regular la respiración y la atención."
          }
        }
      }
    },
    "exercise.breathing_444.summary" : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un ritmo simple para bajar revoluciones."
          }
        }
      }
    },
    "exercise.breathing_444.title" : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Respiración 4-4-4"
          }
        }
      }
    },
