        }
      }
    },
    "emotion_support.cansado" : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tu cuerpo y tu cabeza pueden estar pidiendo una pausa simple."
          }
        }
      }
    },
    "emotion_support.frustrado" : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bajar un poco la exigencia por unos minutos puede destrabar el momento."
          }
        }
      }
    },
    "emotion_support.tranquilo" : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Parece que hoy hay un poco más de aire. Puedes sostener ese ritmo."
          }
        }
      }
    },
    "emotion_support.triste" : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
